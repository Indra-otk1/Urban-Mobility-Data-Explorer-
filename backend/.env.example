# Copy this file to .env and fill in your local MySQL credentials.
# Never commit the real .env file.

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=changeme
DB_NAME=urban_mobility

PORT=4000

# Path to the raw data files (relative to project root)
TRIP_PARQUET_PATH=./data/yellow_tripdata_2019-01.parquet
ZONE_LOOKUP_CSV_PATH=./data/taxi_zone_lookup.csv
ZONE_GEOJSON_PATH=./data/taxi_zones.geojson

